APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://localhost
APP_FRONTEND_URL=
APP_FRONTEND_PORTAL_URL=https://vacantes.decorartereposteria.mx
# Opcional: si se define, sobreescribe APP_FRONTEND_PORTAL_URL para el callback de Google OAuth.
# FRONTEND_PORTAL_URL=https://vacantes.decorartereposteria.mx

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# En producción con dominios cruzados (portal en Vercel + backend en Railway)
# usar SESSION_SECURE_COOKIE=true y SESSION_SAME_SITE=none.
# En desarrollo local usar SESSION_SECURE_COOKIE=false y SESSION_SAME_SITE=lax.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

BROADCAST_CONNECTION=log
# Disco por defecto para archivos. Usar 's3' en producción con bucket privado.
# 'local' es aceptable solo en desarrollo; NUNCA usar 'public' para PII/evidencias.
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
RESEND_API_KEY=your_resend_api_key_here
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=notificaciones@decorartereposteria.mx
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Dominios stateful de Sanctum. En producción incluir el dominio del portal.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,vacantes.decorartereposteria.mx

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://vacantes.decorartereposteria.mx/auth/google/callback

WHATSAPP_API_KEY=
WHATSAPP_PHONE=524626269090
